# ── Google Gemini API ────────────────────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Firebase ────────────────────────────────────────────────────────────────
# Ensure you have placed `serviceAccountKey.json` inside the `backend` directory.
# Do not modify FIREBASE_SERVICE_ACCOUNT_PATH unless you change the mount point.
FIREBASE_PROJECT_ID=your_firebase_project_id

# ── Twilio SMS ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+15551234567
SMS_DEMO_TO_NUMBER=+923001234567

# ── App Config ──────────────────────────────────────────────────────────────
SMS_MODE=mock
LOG_LEVEL=INFO
